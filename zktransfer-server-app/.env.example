HOST=127.0.0.1
PORT=4010
# Replace before deployment; readiness fails if the default development secret is used.
JWT_SECRET=replace-with-a-real-secret

# Standard zkWallet proving workspace
CIRCUITS_ROOT=/Users/hyunokoh/Documents/zkWallet/zk-wallet-circuits

# Fail closed if a legacy leaf_pos proof-input contract appears
ALLOW_LEGACY_PROOF_INPUTS=0

PROOF_SETUP_MODE=fresh
PROOF_TREE_HEIGHT=11
PROOF_TIMEOUT_MS=120000
SUPPORTED_NETWORKS=hardhat-local,kaia-testnet
HOT_WALLET_ADDRESS=0xCcCCccccCCCCcCCCCCCcCcCccCcCCCcCcccccccC

# zkpasskey social recovery relayer (required for on-chain social account creation and updateTxKey recovery)
ZKPASSKEY_RPC_URL=
ZKPASSKEY_ENTRY_POINT_ADDRESS=
ZKPASSKEY_RELAYER_PRIVATE_KEY=
ZKPASSKEY_BENEFICIARY_ADDRESS=
ZKPASSKEY_MERKLE_TREE_ADDRESS=
ZKPASSKEY_FACTORY_ADDRESS=
ZKPASSKEY_VERIFIER_ADDRESS=
ZKPASSKEY_CREATE_ACCOUNT_FUNDING_WEI=0
ZKPASSKEY_RECOVERY_FUNDING_WEI=0
ZKPASSKEY_VERIFICATION_GAS_LIMIT=1500000
ZKPASSKEY_CALL_GAS_LIMIT=1500000
ZKPASSKEY_PRE_VERIFICATION_GAS=100000
ZKPASSKEY_MAX_FEE_PER_GAS=1000000000
ZKPASSKEY_MAX_PRIORITY_FEE_PER_GAS=1000000000
